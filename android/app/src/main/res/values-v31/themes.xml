<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Android 12+ SplashScreen API.

        Sur Android 12+, windowSplashScreenAnimatedIcon est TOUJOURS clipé
        en cercle (adaptive icon behavior). Pour afficher le logo sans cercle,
        on utilise windowSplashScreenBrandingImage (zone branding bas d'écran)
        ou on passe par une image transparente pour l'icône et on laisse le
        fond noir afficher l'image via windowSplashScreenBackground drawable.

        Solution retenue : fond noir + icône vide (1px transparent) +
        branding image = logo complet affiché proprement sans conteneur rond.
    -->
    <style name="LaunchTheme" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#000000</item>
        <!-- Icône vide pour éviter le cercle Android 12+ -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="windowSplashScreenIconBackgroundColor">#00000000</item>
        <!-- Logo affiché en branding (bas d'écran, sans clip) -->
        <item name="android:windowSplashScreenBrandingImage">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
