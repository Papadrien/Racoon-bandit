<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Android 12+ SplashScreen API.

        windowSplashScreenAnimatedIcon est toujours clippé en cercle par le
        système — on le rend transparent pour l'esquiver complètement.

        L'image plein écran est portée par windowSplashScreenBackground via
        un drawable layer-list (fond noir + bitmap en gravity="fill").
        C'est la seule façon d'avoir une image couvrant tout l'écran sur
        Android 12+ sans passer par le slot icône.
    -->
    <style name="LaunchTheme" parent="Theme.SplashScreen">
        <!-- Image plein écran portée par le fond -->
        <item name="windowSplashScreenBackground">@drawable/splash_fullscreen</item>
        <!-- Icône vide pour éviter le cercle Android 12+ -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="windowSplashScreenIconBackgroundColor">#00000000</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
